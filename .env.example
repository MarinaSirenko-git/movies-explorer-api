# Порт HTTP-сервера (на Render задаётся платформой)
PORT=3001

# MongoDB: локально или строка подключения MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:<db_password>@CLUSTER.mongodb.net/moviesdb?retryWrites=true&w=majority

# Секрет для подписи JWT (в production — длинная случайная строка)
SECRET_KEY=

# Разрешённые origin для CORS, через запятую (если не задано — встроенный список по умолчанию)
# ALLOWED_ORIGINS=http://localhost:3000,https://movies-explorer-frontend.pages.dev
